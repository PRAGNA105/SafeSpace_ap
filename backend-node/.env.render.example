# Render environment variables for backend-node

# Comma-separated list is supported if you want both production and preview URLs
FRONTEND_ORIGIN=https://your-frontend.vercel.app
FRONTEND_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number
ADMIN_SUPPORT_PHONE=your-admin-support-phone

SARVAM_API_KEY=your-sarvam-api-key
SARVAM_API_SUBSCRIPTION_KEY=your-sarvam-subscription-key
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_CHAT_MODEL=sarvam-30b
SARVAM_TTS_SPEAKER=priya
