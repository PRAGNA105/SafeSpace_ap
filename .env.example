# Frontend environment variables for local development and production

# Google OAuth client ID used by the React app
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Hosted PHP API base URL
# Local example: http://127.0.0.1:8000/api
# Production example: https://api.yourdomain.com/api
VITE_API_URL=http://127.0.0.1:8000/api

# Hosted chatbot endpoint from backend-node
# Local example: http://127.0.0.1:5001/api/chatbot
# Production example: https://chat.yourdomain.com/api/chatbot
VITE_CHATBOT_API_URL=http://127.0.0.1:5001/api/chatbot

# Optional: enables prescription OCR through Groq
VITE_GROQ_API_KEY=your-groq-api-key
