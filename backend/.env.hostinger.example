# Hostinger/cPanel environment variables for backend/
# This file should be copied to backend/.env on the server.

SAFESPACE_FRONTEND_ORIGIN=https://your-frontend.vercel.app
SAFESPACE_FRONTEND_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com

SAFESPACE_DB_HOST=localhost
SAFESPACE_DB_PORT=3306
SAFESPACE_DB_NAME=your_hostinger_database_name
SAFESPACE_DB_USER=your_hostinger_database_user
SAFESPACE_DB_PASS=your_hostinger_database_password

# Optional remote MySQL CA certificate path if your provider requires it
SAFESPACE_DB_CA=
